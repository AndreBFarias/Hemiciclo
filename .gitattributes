# Normalizacao de line endings
* text=auto eol=lf

# Scripts Windows preservam CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Python
*.py text diff=python
*.pyi text diff=python

# Configs
*.toml text
*.yaml text
*.yml text
*.json text
*.md text
*.cfg text
*.ini text

# Binarios -- nunca tratar como texto
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pkl binary
*.parquet binary
*.duckdb binary
*.zip binary
*.gz binary
*.tar binary
*.whl binary
